{
  "name": "park-tycoon",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "asbuild:debug": "asc assembly/index.ts --target debug",
    "asbuild:release": "asc assembly/index.ts --target release",
    "asbuild": "npm run asbuild:release",
    "dev": "npm run asbuild && vite",
    "build": "npm run asbuild && tsc && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "npm run asbuild && vitest run",
    "test:coverage": "npm run asbuild && vitest run --coverage",
    "test:watch": "npm run asbuild && vitest",
    "test:e2e": "npm run build && playwright test",
    "test:all": "npm run test && npm run test:e2e"
  },
  "dependencies": {
    "pixi.js": "^7.3.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@vitest/coverage-v8": "^4.0.18",
    "assemblyscript": "^0.27.29",
    "typescript": "^5.4.0",
    "vite": "^5.4.0",
    "vitest": "^4.0.18"
  }
}
